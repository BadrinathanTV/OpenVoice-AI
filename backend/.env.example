OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ASR_MODEL_PATH=/path/to/Qwen3-ASR-0.6B
ASR_BACKEND=transformers
ASR_LANGUAGE=English
ASR_STREAMING_CHUNK_SIZE_SEC=0.64
ASR_ALLOW_BACKEND_FALLBACK=true
ASR_ENFORCE_ENGLISH=true
ASR_ENGLISH_CONFIDENCE_THRESHOLD=0.80
ASR_ENGLISH_MIN_CHARS=24
ASR_ENGLISH_MIN_WORDS=5
# If you set ASR_BACKEND=vllm, install the extra first:
# uv sync --extra streaming-asr
# Optional vLLM tuning:
# ASR_TENSOR_PARALLEL_SIZE=1
# ASR_GPU_MEMORY_UTILIZATION=0.85
# ASR_VLLM_MAX_MODEL_LEN=8192
# If unset, the backend defaults to 8192 so local GPUs do not try to serve
# the model's full 65536-token context window.
DATABASE_URL=mongodb://localhost:27017/
